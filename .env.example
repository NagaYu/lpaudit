# ---------------------------------------------------------------------------
# LPAudit environment configuration
# Copy this file to ".env" and fill in your credentials.
# ---------------------------------------------------------------------------

# --- OpenAI (used when --provider openai, the default) ---------------------
OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1   # override for proxies/gateways

# --- Google Gemini (used when --provider gemini) ---------------------------
# GEMINI_API_KEY=your-gemini-key-here
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# --- LPAudit defaults ------------------------------------------------------
# LPAUDIT_PROVIDER=openai        # openai | gemini
# LPAUDIT_MODEL=gpt-4o-mini      # default model when --model is omitted
# LPAUDIT_FAIL_OVER=60           # riskScore at/above which exit code is 2
